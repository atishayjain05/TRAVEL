# FoodScout AI — Environment Variables
# Copy this file to .env and fill in your values

# ─── API Keys ────────────────────────────────────────────────────────────────
YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here
GOOGLE_MAPS_API_KEY=your_google_places_api_key_here

# OpenAI-compatible LLM (supports Groq, OpenRouter, or OpenAI)
OPENAI_API_KEY=your_openai_or_groq_api_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1
OPENAI_MODEL=llama3-8b-8192

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/foodscout

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── App Config ───────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Google Sheets (optional) ─────────────────────────────────────────────────
GOOGLE_SHEETS_CREDENTIALS_FILE=credentials.json
